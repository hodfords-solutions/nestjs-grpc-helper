{
    "name": "@hodfords/nestjs-grpc-helper",
    "version": "11.4.0-rc.25",
    "description": "A utility for simplifying gRPC integration and communication in NestJS applications",
    "author": "",
    "license": "UNLICENSED",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hodfords-solutions/nestjs-grpc-helper.git"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "nest build",
        "format": "prettier --write \"sample/**/*.ts\" \"lib/**/*.ts\"",
        "start:dev": "npm run prebuild && nest start --watch",
        "build:sample-sdk": "npm run prebuild && nest start -- --exit",
        "postbuild": "cp package.json dist/lib && cp README.md dist/lib && cp .npmrc dist/lib",
        "lint": "eslint \"{sample,apps,lib,test}/**/*.ts\" --fix",
        "wz-command": "wz-command",
        "prepare": "is-ci || husky",
        "version": "auto-changelog && git add CHANGELOG.md",
        "release:patch": "git add CHANGELOG.md && npm version patch --tag-version-prefix='' -f -m 'chore: release to %s'",
        "release:push": "git push --no-verify && git push --tags --no-verify",
        "build-sdk": "nestjs-grpc-helper",
        "cspell": "cspell",
        "lint-staged": "lint-staged"
    },
    "dependencies": {
        "@faker-js/faker": "*",
        "@grpc/grpc-js": "*",
        "@grpc/proto-loader": "*",
        "handlebars": "4.7.8"
    },
    "peerDependencies": {
        "@faker-js/faker": "*",
        "@grpc/grpc-js": "*",
        "@grpc/proto-loader": "*",
        "@hodfords/nestjs-cls-translation": "*",
        "chalk": "*",
        "shelljs": "*"
    },
    "devDependencies": {
        "@hodfords/nestjs-exception": "^11.0.2",
        "@hodfords/nestjs-cls-translation": "11.1.0",
        "@hodfords/nestjs-command": "11.0.9",
        "@hodfords/nestjs-eslint-config": "11.0.2",
        "@hodfords/nestjs-prettier-config": "11.0.1",
        "@hodfords/nestjs-response": "11.0.10",
        "@nestjs/cli": "11.0.16",
        "@nestjs/common": "11.1.12",
        "@nestjs/core": "11.1.12",
        "@nestjs/microservices": "11.1.12",
        "@nestjs/platform-express": "11.1.12",
        "@nestjs/schematics": "11.0.9",
        "@nestjs/serve-static": "5.0.4",
        "@nestjs/swagger": "11.2.5",
        "@nestjs/testing": "11.1.12",
        "@nestjs/typeorm": "11.0.0",
        "@types/express": "5.0.6",
        "@types/jest": "30.0.0",
        "@types/lodash": "4.17.23",
        "@types/node": "25.2.0",
        "@types/supertest": "6.0.3",
        "auto-changelog": "2.5.0",
        "class-transformer": "0.5.1",
        "class-validator": "0.14.3",
        "cspell": "9.6.3",
        "eslint": "9.39.2",
        "husky": "9.1.7",
        "is-ci": "4.1.0",
        "jest": "30.2.0",
        "lint-staged": "16.2.7",
        "lodash": "^4.17.23",
        "reflect-metadata": "0.2.2",
        "rimraf": "6.1.2",
        "rxjs": "7.8.2",
        "source-map-support": "0.5.21",
        "sqlite3": "^5.1.7",
        "supertest": "7.2.2",
        "ts-jest": "29.4.6",
        "ts-loader": "9.5.4",
        "ts-node": "10.9.2",
        "tsconfig-paths": "4.2.0",
        "typeorm": "0.3.28",
        "typescript": "5.9.3"
    },
    "overrides": {
        "tar": "^7.5.7",
        "lodash": "^4.17.23"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "./coverage",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/sample/",
            "<rootDir>/lib/"
        ],
        "moduleNameMapper": {
            "^@hodfords/nestjs-grpc-helper(|/.*)$": "<rootDir>/lib/nestjs-grpc-helper/src/$1"
        }
    }
}
